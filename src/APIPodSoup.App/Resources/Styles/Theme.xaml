<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Dark Theme Colors -->
    <SolidColorBrush x:Key="BgPrimary" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="BgSecondary" Color="#2B2B3D"/>
    <SolidColorBrush x:Key="BgTertiary" Color="#363650"/>
    <SolidColorBrush x:Key="BgElevated" Color="#3E3E5C"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#E0E0F0"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#A0A0C0"/>
    <SolidColorBrush x:Key="AccentPrimary" Color="#7C5CFC"/>
    <SolidColorBrush x:Key="AccentHover" Color="#9168FF"/>
    <SolidColorBrush x:Key="AccentPressed" Color="#6A4BE0"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#4ADE80"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FBBF24"/>
    <SolidColorBrush x:Key="ErrorColor" Color="#F87171"/>
    <SolidColorBrush x:Key="BorderColor" Color="#4A4A6A"/>
    <SolidColorBrush x:Key="BorderSubtle" Color="#3A3A55"/>

    <!-- Font Sizes -->
    <sys:Double x:Key="FontSizeXs">11</sys:Double>
    <sys:Double x:Key="FontSizeSm">12</sys:Double>
    <sys:Double x:Key="FontSizeBase">14</sys:Double>
    <sys:Double x:Key="FontSizeLg">16</sys:Double>
    <sys:Double x:Key="FontSizeXl">20</sys:Double>
    <sys:Double x:Key="FontSize2Xl">24</sys:Double>

    <!-- Corner Radius -->
    <CornerRadius x:Key="CornerRadiusSm">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMd">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLg">12</CornerRadius>

    <!-- Common Styles -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgPrimary}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}"/>
    </Style>

    <Style x:Key="LabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="HeadingStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeXl}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="SubHeadingStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
    </Style>
</ResourceDictionary>
