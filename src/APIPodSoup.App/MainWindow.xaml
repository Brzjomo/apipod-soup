<Window x:Class="APIPodSoup.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:APIPodSoup.App.ViewModels"
        xmlns:views="clr-namespace:APIPodSoup.App.Views"
        xmlns:converters="clr-namespace:APIPodSoup.App.Converters"
        xmlns:loc="clr-namespace:APIPodSoup.App.Markup"
        Title="{loc:Loc Key=App.Title}"
        Height="800" Width="1300"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:StringNotEmptyConverter x:Key="StrNotEmpty"/>
        <converters:NavigationButtonActiveConverter x:Key="NavActive"/>

        <DataTemplate DataType="{x:Type vm:TextToImageViewModel}">
            <views:TextToImagePage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TextToVideoViewModel}">
            <views:TextToVideoPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <views:AboutPage/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.RowSpan="2"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="12">
                <TextBlock Text="{loc:Loc Key=App.Brand}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource AccentPrimary}"
                           Margin="8,16,8,24"/>

                <!-- Navigation Items -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="{loc:Loc Key=Nav.Generation}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11" FontWeight="Bold"
                               Margin="8,0,0,8"/>
                    <Button Content="{loc:Loc Key=Nav.TextToImage}"
                            Command="{Binding NavigateCommand}" CommandParameter="TextToImage"
                            Style="{StaticResource NavButtonStyle}"
                            Foreground="{Binding SelectedNavItem, Converter={StaticResource NavActive}, ConverterParameter=TextToImage}"/>
                    <Button Content="{loc:Loc Key=Nav.TextToVideo}"
                            Command="{Binding NavigateCommand}" CommandParameter="TextToVideo"
                            Style="{StaticResource NavButtonStyle}"
                            Foreground="{Binding SelectedNavItem, Converter={StaticResource NavActive}, ConverterParameter=TextToVideo}"/>
                </StackPanel>

                <Separator Background="{StaticResource BorderSubtle}" Margin="8,4"/>

                <StackPanel Margin="0,12,0,0">
                    <TextBlock Text="{loc:Loc Key=Nav.Manage}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11" FontWeight="Bold"
                               Margin="8,0,0,8"/>
                    <Button Content="{loc:Loc Key=Nav.History}"
                            Command="{Binding NavigateCommand}" CommandParameter="History"
                            Style="{StaticResource NavButtonStyle}"
                            Foreground="{Binding SelectedNavItem, Converter={StaticResource NavActive}, ConverterParameter=History}"/>
                    <Button Content="{loc:Loc Key=Nav.Settings}"
                            Command="{Binding NavigateCommand}" CommandParameter="Settings"
                            Style="{StaticResource NavButtonStyle}"
                            Foreground="{Binding SelectedNavItem, Converter={StaticResource NavActive}, ConverterParameter=Settings}"/>
                    <Button Content="{loc:Loc Key=Nav.About}"
                            Command="{Binding NavigateCommand}" CommandParameter="About"
                            Style="{StaticResource NavButtonStyle}"
                            Foreground="{Binding SelectedNavItem, Converter={StaticResource NavActive}, ConverterParameter=About}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1" Background="{StaticResource BgPrimary}">
            <ContentControl Content="{Binding CurrentView}"
                            Margin="0"/>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                         Fill="{StaticResource SuccessColor}"
                         Margin="0,0,6,0"
                         Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"/>
                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                         Fill="{StaticResource ErrorColor}"
                         Margin="0,0,6,0"
                         Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
