<UserControl x:Class="APIPodSoup.App.Views.TextToImagePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:APIPodSoup.App.Converters"
             xmlns:loc="clr-namespace:APIPodSoup.App.Markup"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:PathToImageConverter x:Key="PathToImage"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,24" MaxWidth="900">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="{loc:Loc Key=TextToImage.Title}" Style="{StaticResource HeadingStyle}"/>
                <TextBlock Text="{loc:Loc Key=TextToImage.Subtitle}" Style="{StaticResource SubHeadingStyle}"/>
            </StackPanel>

            <!-- Model Selector -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Loc Key=TextToImage.Model}" VerticalAlignment="Center"
                               Style="{StaticResource LabelStyle}" Margin="0,0,16,0"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Models}"
                              SelectedItem="{Binding SelectedModel}"
                              DisplayMemberPath="DisplayName"
                              Width="240" HorizontalAlignment="Left"/>
                </Grid>
            </Border>

            <!-- Prompt -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding PromptLabel}" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinLines="4" MaxLines="8"
                             MaxLength="{Binding PromptMaxLength}"/>
                    <TextBlock HorizontalAlignment="Right"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11" Margin="0,4,0,0">
                        <Run Text="{Binding Prompt.Length, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding PromptMaxLength}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Parameters -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Key=TextToImage.Parameters}" Style="{StaticResource LabelStyle}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding ShowAspectRatio, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{loc:Loc Key=TextToImage.AspectRatio}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding AspectRatios}"
                                      SelectedItem="{Binding SelectedAspectRatio}"
                                      Width="140"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding ShowQuality, Converter={StaticResource BoolToVis}}"
                                    Margin="24,0,0,0">
                            <TextBlock Text="{loc:Loc Key=TextToImage.Quality}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding Qualities}"
                                      SelectedItem="{Binding SelectedQuality}"
                                      Width="120"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Reference Images -->
            <Border Grid.Row="4" Style="{StaticResource DropZoneCardStyle}"
                    Margin="0,0,0,16"
                    AllowDrop="True"
                    DragEnter="OnDragEnter" DragLeave="OnDragLeave" Drop="OnDrop"
                    Visibility="{Binding ShowReferenceSection, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{Binding ReferenceLabel}" Style="{StaticResource LabelStyle}" Margin="0,0,0,0"/>
                        <TextBlock Text="{Binding ReferenceLimitText}"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11"
                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding OssStatus}"
                               Foreground="{StaticResource WarningColor}"
                               FontSize="11" Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc Key=TextToImage.DropHint}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="12" Margin="0,4,0,8"/>
                    <Button Content="{loc:Loc Key=TextToImage.Browse}"
                            Command="{Binding AddReferenceImagesCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Left"/>
                    <!-- Thumbnails -->
                    <ItemsControl ItemsSource="{Binding ReferenceImages}" Margin="0,12,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgTertiary}"
                                        CornerRadius="6" Width="100" Height="100"
                                        Margin="0,0,8,8">
                                    <Grid>
                                        <Image Source="{Binding Converter={StaticResource PathToImage}}" Stretch="UniformToFill"/>
                                        <Button Style="{StaticResource IconButtonStyle}"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Width="22" Height="22"
                                                Margin="2"
                                                Background="{StaticResource BgPrimary}"
                                                Opacity="0.85"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.RemoveReferenceImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="11"
                                                            Opacity="{TemplateBinding Opacity}">
                                                        <TextBlock Text="&#xE711;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Generate Button + Progress -->
            <StackPanel Grid.Row="5" Margin="0,0,0,16">
                <Button Content="{loc:Loc Key=TextToImage.Generate}"
                        Command="{Binding GenerateCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="44" Width="200"
                        IsEnabled="{Binding IsProcessing, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                        FontSize="16"/>

                <!-- Progress -->
                <Border Margin="0,12,0,0"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding StepText}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="12"/>
                        <ProgressBar Minimum="0" Maximum="1"
                                     Value="{Binding Progress}"
                                     Height="6"
                                     Margin="0,8,0,4"
                                     Foreground="{StaticResource AccentPrimary}"
                                     Background="{StaticResource BgTertiary}"/>
                        <TextBlock Text="{Binding ProgressText}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Results -->
            <Border Grid.Row="6"
                    Style="{StaticResource CardStyle}"
                    Visibility="{Binding ResultImages.Count, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Key=TextToImage.Results}" Style="{StaticResource LabelStyle}" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding ResultImages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgTertiary}"
                                        CornerRadius="8" Width="256"
                                        Margin="0,0,12,12">
                                    <StackPanel>
                                        <Image Source="{Binding Converter={StaticResource PathToImage}}"
                                               Stretch="Uniform"
                                               Height="256"
                                               Cursor="Hand"
                                               MouseLeftButtonDown="OnResultImageClick"
                                               Tag="{Binding}"/>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,6,0,8">
                                            <Button Content="{loc:Loc Key=TextToImage.Preview}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="8,4" FontSize="11"
                                                    Margin="0,0,6,0"
                                                    Command="{Binding DataContext.OpenResultInDefaultAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="{loc:Loc Key=TextToImage.OpenFolder}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenResultFolderCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
