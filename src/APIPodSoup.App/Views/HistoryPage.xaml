<UserControl x:Class="APIPodSoup.App.Views.HistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:APIPodSoup.App.Converters"
             xmlns:loc="clr-namespace:APIPodSoup.App.Markup"
             Background="{StaticResource BgPrimary}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:UtcToLocalConverter x:Key="UtcToLocal"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,24" MaxWidth="900">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Key=History.Title}" Style="{StaticResource HeadingStyle}"/>
                        <TextBlock Text="{loc:Loc Key=History.Subtitle}"
                                   Style="{StaticResource SubHeadingStyle}"/>
                    </StackPanel>
                    <Button Content="{loc:Loc Key=History.Refresh}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- Loading -->
            <TextBlock Grid.Row="1" Text="{loc:Loc Key=History.Loading}"
                       Foreground="{StaticResource TextSecondary}"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                       Margin="0,0,0,16"/>

            <!-- Empty State -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}"
                    Visibility="{Binding Records.Count, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                <TextBlock Text="{loc:Loc Key=History.Empty}"
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0,40"/>
            </Border>

            <!-- History List -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding Records}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource HistoryCardStyle}"
                                MouseLeftButtonDown="OnRecordClick"
                                Tag="{Binding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Status indicator -->
                                <Border Width="8" Height="8" CornerRadius="4"
                                        Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                        VerticalAlignment="Top" Margin="0,4,12,0"/>

                                <!-- Content -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding ModelDisplayName}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="{Binding Prompt}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="600"
                                               Margin="0,4,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="11"/>
                                        <TextBlock Text=" | " Foreground="{StaticResource BorderColor}" FontSize="11"/>
                                        <TextBlock Text="{Binding CreatedAt, Converter={StaticResource UtcToLocal}, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                    <Button Content="{loc:Loc Key=History.Delete}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Padding="8,4" FontSize="11"
                                            Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
