<UserControl x:Class="APIPodSoup.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:APIPodSoup.App.Converters"
             xmlns:loc="clr-namespace:APIPodSoup.App.Markup"
             xmlns:vm="clr-namespace:APIPodSoup.App.ViewModels"
             Background="{StaticResource BgPrimary}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,24" MaxWidth="700">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="{loc:Loc Key=Settings.Title}" Style="{StaticResource HeadingStyle}"/>
                <TextBlock Text="{loc:Loc Key=Settings.Subtitle}"
                           Style="{StaticResource SubHeadingStyle}"/>
            </StackPanel>

            <!-- Language -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Key=Settings.LanguageSection}" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                    <TextBlock Text="{loc:Loc Key=Settings.Language}" Style="{StaticResource LabelStyle}"/>
                    <ComboBox ItemsSource="{x:Static vm:SettingsViewModel.AvailableLanguages}"
                              SelectedValue="{Binding SelectedLanguage}"
                              SelectedValuePath="Code"
                              DisplayMemberPath="DisplayName"
                              Width="200" HorizontalAlignment="Left"/>
                    <TextBlock Text="{loc:Loc Key=Settings.LanguageHint}"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- API Settings -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Key=Settings.ApiSection}" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                    <TextBlock Text="{loc:Loc Key=Settings.ApiKey}" Style="{StaticResource LabelStyle}"/>

                    <!-- API Key: both hidden/visible use TextBox for consistent sizing -->
                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Hidden: readonly TextBox displaying fixed 12 dots -->
                        <TextBox Grid.Column="0"
                                 Text="&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;"
                                 IsReadOnly="True" Cursor="Hand"
                                 Foreground="{StaticResource TextSecondary}"
                                 Visibility="{Binding ShowApiKeyMask, Converter={StaticResource BoolToVis}}"
                                 MouseLeftButtonDown="OnApiKeyMaskClicked"/>
                        <!-- Visible: editable TextBox -->
                        <TextBox Grid.Column="0"
                                 Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding CanShowApiKeyEdit, Converter={StaticResource BoolToVis}}"/>
                        <!-- Eye button -->
                        <Button Grid.Column="1" Content="👁"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding ToggleApiKeyVisibilityCommand}"
                                Visibility="{Binding ShowApiKeyEye, Converter={StaticResource BoolToVis}}"
                                Width="28" Height="28" FontSize="14"
                                Background="Transparent" BorderThickness="0"
                                Margin="6,0,0,0" Padding="0"/>
                    </Grid>

                    <TextBlock Text="{loc:Loc Key=Settings.ApiBaseUrl}" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                    <TextBlock Text="{loc:Loc Key=Settings.ApiBaseUrlHint}"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                             Width="400" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- OSS Settings -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Key=Settings.OssSection}" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>

                    <!-- Access Key -->
                    <TextBlock Text="{loc:Loc Key=Settings.OssAccessKey}" Style="{StaticResource LabelStyle}"/>
                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;"
                                 IsReadOnly="True" Cursor="Hand"
                                 Foreground="{StaticResource TextSecondary}"
                                 Visibility="{Binding ShowOssAkMask, Converter={StaticResource BoolToVis}}"
                                 MouseLeftButtonDown="OnOssAkMaskClicked"/>
                        <TextBox Grid.Column="0"
                                 Text="{Binding OssAccessKey, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding CanShowOssAkEdit, Converter={StaticResource BoolToVis}}"/>
                        <Button Grid.Column="1" Content="👁"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding ToggleOssAkVisibilityCommand}"
                                Visibility="{Binding ShowOssAkEye, Converter={StaticResource BoolToVis}}"
                                Width="28" Height="28" FontSize="14"
                                Background="Transparent" BorderThickness="0"
                                Margin="6,0,0,0" Padding="0"/>
                    </Grid>

                    <!-- Secret Key -->
                    <TextBlock Text="{loc:Loc Key=Settings.OssSecretKey}" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;"
                                 IsReadOnly="True" Cursor="Hand"
                                 Foreground="{StaticResource TextSecondary}"
                                 Visibility="{Binding ShowOssSkMask, Converter={StaticResource BoolToVis}}"
                                 MouseLeftButtonDown="OnOssSkMaskClicked"/>
                        <TextBox Grid.Column="0"
                                 Text="{Binding OssSecretKey, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding CanShowOssSkEdit, Converter={StaticResource BoolToVis}}"/>
                        <Button Grid.Column="1" Content="👁"
                                Style="{StaticResource IconButtonStyle}"
                                Command="{Binding ToggleOssSkVisibilityCommand}"
                                Visibility="{Binding ShowOssSkEye, Converter={StaticResource BoolToVis}}"
                                Width="28" Height="28" FontSize="14"
                                Background="Transparent" BorderThickness="0"
                                Margin="6,0,0,0" Padding="0"/>
                    </Grid>

                    <TextBlock Text="{loc:Loc Key=Settings.OssEndpoint}" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding OssEndpoint, UpdateSourceTrigger=PropertyChanged}"
                             Width="400" HorizontalAlignment="Left"/>
                    <TextBlock Text="{loc:Loc Key=Settings.OssRegion}" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding OssRegion, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" HorizontalAlignment="Left"/>
                    <TextBlock Text="{loc:Loc Key=Settings.OssBucketName}" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding OssBucketName, UpdateSourceTrigger=PropertyChanged}"
                             Width="300" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Download Settings -->
            <Border Grid.Row="4" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Key=Settings.StorageSection}" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                    <TextBlock Text="{loc:Loc Key=Settings.DownloadDir}" Style="{StaticResource LabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding DownloadDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="{loc:Loc Key=Settings.Browse}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding BrowseDownloadDirCommand}"
                                Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save -->
            <StackPanel Grid.Row="5">
                <Button Content="{loc:Loc Key=Settings.Save}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"
                        Width="160" Height="40"
                        HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding SaveStatus}"
                           Foreground="{StaticResource SuccessColor}"
                           FontSize="12" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
