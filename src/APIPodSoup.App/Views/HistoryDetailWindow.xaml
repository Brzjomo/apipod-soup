<Window x:Class="APIPodSoup.App.Views.HistoryDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:APIPodSoup.App.Converters"
        xmlns:loc="clr-namespace:APIPodSoup.App.Markup"
        Title="{loc:Loc Key=Detail.Title}" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StringNotEmptyConverter x:Key="StrNotEmpty"/>
        <converters:PathToImageConverter x:Key="PathToImage"/>
        <converters:UtcToLocalConverter x:Key="UtcToLocal"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="{Binding ModelDisplayName}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource AccentPrimary}"
                       Margin="0,0,0,12"/>

            <UniformGrid Columns="2" Margin="0,0,0,12">
                <!-- Row 0 -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,8,12">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Key=Detail.Status}" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="8,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Key=Detail.Elapsed}" Style="{StaticResource LabelStyle}"/>
                        <TextBlock x:Name="ElapsedText" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                </Border>
                <!-- Row 1 -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,8,12">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Key=Detail.TaskId}" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding TaskId}" Foreground="{StaticResource TextPrimary}"
                                   TextTrimming="CharacterEllipsis" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="8,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Key=Detail.Created}" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding CreatedAt, Converter={StaticResource UtcToLocal}, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                   Foreground="{StaticResource TextPrimary}" FontSize="11"/>
                    </StackPanel>
                </Border>
                <!-- Row 2 -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,8,12">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Key=Detail.AspectRatio}" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding AspectRatio}" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="8,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Key=Detail.Quality}" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Quality}" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Prompt -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Key=Detail.Prompt}" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding Prompt}"
                             IsReadOnly="True" TextWrapping="Wrap"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextPrimary}" Padding="0"/>
                </StackPanel>
            </Border>

            <!-- Results -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12"
                    Visibility="{Binding LocalResultPaths, Converter={StaticResource StrNotEmpty}}">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{loc:Loc Key=Detail.Results}" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <Button Content="{loc:Loc Key=Detail.ExportAll}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,4" FontSize="11"
                                HorizontalAlignment="Right"
                                Click="OnExportClick"/>
                    </Grid>
                    <TextBlock x:Name="VideoHint"
                               Text="{loc:Loc Key=Detail.VideoHint}"
                               Foreground="{StaticResource WarningColor}"
                               FontSize="12" Margin="0,0,0,8"
                               Visibility="Collapsed"/>

                    <ItemsControl x:Name="ResultItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,12,12">
                                    <!-- Image display -->
                                    <Image Source="{Binding Image}"
                                           Stretch="Uniform"
                                           Width="200" Height="200"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="OnImageClick"
                                           Visibility="{Binding IsVideo, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                    <!-- Video placeholder -->
                                    <Border Width="200" Height="200"
                                            Background="{StaticResource BgSecondary}"
                                            CornerRadius="8"
                                            Visibility="{Binding IsVideo, Converter={StaticResource BoolToVis}}">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE714;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="48"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{loc:Loc Key=Detail.VideoLabel}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{Binding FileName}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="10" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="200"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{loc:Loc Key=Detail.ReuseParams}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnReuseClick"
                        Margin="0,0,12,0" Padding="12,8" FontSize="12"/>
                <Button Content="{loc:Loc Key=Detail.Close}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="OnCloseClick"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
